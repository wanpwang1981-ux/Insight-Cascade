# This is an example file for environment variables.
# To use the application, you need to:
# 1. Rename this file to ".env".
# 2. Fill in the necessary variables below.

# --- Gemini API (Cloud-based) ---
# Get your API key from Google AI Studio (https://aistudio.google.com/).
GEMINI_API_KEY="YOUR_API_KEY_HERE"


# --- Ollama (Local) ---
# If your Ollama service is running on a different machine, specify its address here.
# If it's running on the same machine (localhost), you can leave this blank.
# Example: OLLAMA_HOST="http://192.168.1.100:11434"
OLLAMA_HOST=